              <span class="px-2.5 py-1 rounded-md bg-surface-container-high text-[10px] font-mono uppercase tracking-widest text-on-surface-variant">Playwright</span>
              <span class="px-2.5 py-1 rounded-md bg-surface-container-high text-[10px] font-mono uppercase tracking-widest text-on-surface-variant">Open Source</span>
            </div>
