            </div>
          </div>
        </div>

        <!-- Lume -->
        <div class="group bg-surface-container rounded-xl overflow-hidden border border-outline-variant/20 card-hover transition-all duration-300">
          <div class="h-72 lg:h-80 overflow-hidden">
