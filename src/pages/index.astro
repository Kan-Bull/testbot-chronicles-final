---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import InteractiveTerminal from '../components/InteractiveTerminal.astro';

// Fetch latest 3 posts from Hashnode at build time
let posts: any[] = [];
try {
  const response = await fetch('https://gql.hashnode.com', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      query: `{
        publication(host: "testbot-chronicles.hashnode.dev") {
          posts(first: 3) {
            edges {
              node {
                title
                brief
                slug
                coverImage { url }
                publishedAt
                tags { name }
              }
            }
          }
        }
      }`
    })
  });
  const data = await response.json();
  posts = data?.data?.publication?.posts?.edges?.map((e: any) => e.node) || [];
} catch (error) {
  console.warn('Failed to fetch Hashnode posts, using fallback');
}

// Fallback if API fails
const fallbackPosts = [
  {
    title: "The Shift-Left Revolution in FinTech",
    brief: "How integrating testing suites directly into the developer environment reduced bug density by 40%.",
    slug: "",
    coverImage: { url: "" },
    publishedAt: "2024-05-12T00:00:00.000Z",
    tags: [{ name: "Case Study" }]
  },
  {
    title: "Visual Regression at Hyper-Speed",
    brief: "AI-driven pixel matching to detect micro-variations across 50+ viewport sizes.",
    slug: "",
    coverImage: { url: "" },
    publishedAt: "2024-04-28T00:00:00.000Z",
    tags: [{ name: "Deep Dive" }]
  },
  {
    title: "From Selenium to Playwright",
    brief: "A data-driven comparison of execution speeds and maintenance overhead for enterprise automation.",
    slug: "",
    coverImage: { url: "" },
    publishedAt: "2024-04-05T00:00:00.000Z",
    tags: [{ name: "Migration Guide" }]
  }
];

const displayPosts = posts.length > 0 ? posts : fallbackPosts;

const tagColors = ['cyan', 'fuchsia', 'cyan'] as const;
---

<BaseLayout title="Home">

  <!-- HERO SECTION -->
  <section class="relative min-h-[921px] flex items-center justify-center px-6 overflow-hidden">
    <div class="absolute inset-0 bg-primary-container z-0"></div>
    <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-secondary/10 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-tertiary/10 blur-[120px] rounded-full"></div>
    <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-10">
      <div class="space-y-8">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface-container-high border-ghost">
          <span class="w-2 h-2 rounded-full bg-tertiary shadow-[0_0_8px_rgba(251,171,255,0.8)]"></span>
          <span class="text-tertiary font-mono text-xs uppercase tracking-widest font-bold">Available for New Projects</span>
        </div>
        <h1 class="text-6xl md:text-7xl font-headline font-extrabold tracking-tighter leading-tight">
          Tech Enabler &amp; <span class="text-gradient">Testing Automation</span> Engineer
