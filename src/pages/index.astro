          </div>
          <div class="space-y-2">
            <label class="text-xs font-mono text-on-surface-variant uppercase tracking-widest font-bold">Work Email</label>
            <input name="email" required class="w-full bg-surface-container-low border-ghost input-focus rounded-xl px-6 py-4 text-on-surface placeholder:text-on-surface/20" placeholder="john@enterprise.com" type="email" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-mono text-on-surface-variant uppercase tracking-widest font-bold">Subject</label>
            <select name="subject" required class="w-full bg-surface-container-low border-ghost input-focus rounded-xl px-6 py-4 text-on-surface">
              <option disabled selected value="">Select an option</option>
              <option value="automation">Testing Automation</option>
              <option value="cicd">CI/CD Consulting</option>
              <option value="performance">Performance Engineering</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="space-y-2">
            <label class="text-xs font-mono text-on-surface-variant uppercase tracking-widest font-bold">Project Details</label>
            <textarea name="message" required class="w-full bg-surface-container-low border-ghost input-focus rounded-xl px-6 py-4 text-on-surface placeholder:text-on-surface/20 resize-none" placeholder="Tell us about your tech stack and testing goals..." rows="4"></textarea>
          </div>
          <button type="submit" class="w-full py-5 rounded-xl font-bold bg-gradient-to-r from-secondary to-tertiary text-on-secondary-fixed shadow-[0_10px_20px_rgba(76,215,246,0.2)] hover:shadow-[0_15px_30px_rgba(76,215,246,0.4)] transition-all">Send Transmission</button>
        </form>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    alert(`Thank you for your message! I'll get back to you soon.\n\nName: ${data.name}\nEmail: ${data.email}\nSubject: ${data.subject}`);
    form.reset();
  });
</script>
