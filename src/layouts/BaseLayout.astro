---
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
  category?: string;
  tags?: string[];
  pubDate?: Date;
  image?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description = "Titus Consulting - Tech Enabler & Testing Automation Engineer",
  category,
  tags = [],
  pubDate,
  image,
  type = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImage = image || "/images/brand/titusLogo.png";
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title} | Titus Consulting</title>

    <!-- OpenGraph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Titus Consulting`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(socialImage, Astro.url)} />
    <meta property="og:site_name" content="Titus Consulting" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${title} | Titus Consulting`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(socialImage, Astro.url)} />

    <!-- Article-specific metadata -->
    {type === 'article' && (
      <>
        <meta property="article:author" content="Titus Consulting" />
        {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
        {category && <meta property="article:section" content={category} />}
        {tags.length > 0 && tags.map(tag => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    )}

    <!-- Keywords for SEO -->
    {tags.length > 0 && (
      <meta name="keywords" content={[
        ...tags,
        ...(category ? [category] : []),
        "testing", "automation", "quality assurance", "TestBot Chronicles"
      ].join(", ")} />
    )}

    <!-- Schema.org structured data -->
    {type === 'article' && (
      <script type="application/ld+json">
        {JSON.stringify({
          "@context": "https://schema.org",
          "@type": "Article",
          "headline": title,
          "description": description,
          "author": {
            "@type": "Organization",
            "name": "Titus Consulting"
          },
          "publisher": {
            "@type": "Organization",
            "name": "Titus Consulting",
            "logo": {
              "@type": "ImageObject",
              "url": new URL("/images/brand/titusLogo.png", Astro.url)
            }
          },
          "datePublished": pubDate?.toISOString(),
          "mainEntityOfPage": {
            "@type": "WebPage",
            "@id": canonicalURL
          },
          "image": new URL(socialImage, Astro.url),
          "articleSection": category,
          "keywords": tags.join(", ")
        })}
      </script>
    )}

    <!-- View Transitions for client-side navigation -->
    <ViewTransitions />
  </head>
  <body class="min-h-screen bg-background text-on-surface">

    <nav class="fixed top-0 w-full z-50 bg-slate-900/60 backdrop-blur-xl shadow-[0_20px_40px_-10px_rgba(76,215,246,0.08)]">
      <div class="flex justify-between items-center px-8 py-4 max-w-7xl mx-auto tracking-tight">
        <a href="/" class="flex items-center gap-3">
          <span class="material-symbols-outlined text-cyan-400 text-3xl" style="font-variation-settings: 'FILL' 1;">pets</span>
          <span class="text-2xl font-bold bg-gradient-to-r from-cyan-400 to-fuchsia-400 bg-clip-text text-transparent">Titus Consulting</span>
        </a>
        <div class="hidden md:flex items-center gap-8 font-medium">
          <a class="text-cyan-400 font-bold border-b-2 border-cyan-400 pb-1" href="/">Home</a>
          <a class="text-slate-400 hover:text-cyan-300 transition-colors" href="#pillars">About</a>
          <a class="text-slate-400 hover:text-cyan-300 transition-colors" href="#blog">Blog</a>
          <a class="text-slate-400 hover:text-cyan-300 transition-colors" href="#contact">Contact</a>
          <a href="#contact" class="bg-gradient-to-r from-secondary to-secondary-container text-on-secondary-fixed px-6 py-2.5 rounded-xl font-bold hover:shadow-[0_0_20px_rgba(76,215,246,0.3)] transition-all">Get Started</a>
        </div>
        <div class="md:hidden text-on-surface">
          <span class="material-symbols-outlined">menu</span>
        </div>
      </div>
    </nav>

    <main class="pt-24">
      <slot />
    </main>

    <footer class="bg-slate-950 w-full border-t border-white/5">
      <div class="flex flex-col md:flex-row justify-between items-center px-12 py-16 w-full max-w-7xl mx-auto text-sm uppercase tracking-widest font-medium">
        <div class="flex flex-col gap-4 items-center md:items-start">
          <div class="text-xl font-black text-slate-100 flex items-center gap-2">
            <span class="material-symbols-outlined text-cyan-400" style="font-variation-settings: 'FILL' 1;">pets</span>
            Titus Consulting
          </div>
          <p class="text-slate-500 max-w-xs text-center md:text-left leading-loose tracking-normal lowercase first-letter:uppercase">&copy; 2025 Titus Consulting. All rights reserved.</p>
        </div>
        <div class="flex flex-wrap justify-center gap-8 mt-12 md:mt-0 font-mono text-[10px]">
          <a class="text-slate-500 hover:text-fuchsia-300 underline-offset-4 hover:underline transition-opacity duration-200 hover:opacity-80" href="#">Privacy Policy</a>
          <a class="text-slate-500 hover:text-fuchsia-300 underline-offset-4 hover:underline transition-opacity duration-200 hover:opacity-80" href="#">Terms of Service</a>
          <a class="text-slate-500 hover:text-fuchsia-300 underline-offset-4 hover:underline transition-opacity duration-200 hover:opacity-80" href="#">Twitter</a>
          <a class="text-slate-500 hover:text-fuchsia-300 underline-offset-4 hover:underline transition-opacity duration-200 hover:opacity-80" href="#">LinkedIn</a>
        </div>
      </div>
    </footer>
  </body>
</html>
