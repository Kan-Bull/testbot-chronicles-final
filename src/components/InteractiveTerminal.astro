---
// Interactive Terminal Component
---

<div id="terminal-container" class="relative group min-w-0 w-full">
  <div
    class="glass-panel border-ghost rounded-xl p-1 overflow-hidden glow-cyan group-hover:border-ghost-active transition-all duration-300 min-w-0"
  >
    <!-- Terminal Header -->
    <div
      class="bg-surface-container-low/80 border-b border-white/5 rounded-t-lg p-3 flex items-center justify-between"
    >
      <div class="flex items-center space-x-2">
        <div
          id="close-btn"
          class="w-3 h-3 bg-[#FF5F56] rounded-full cursor-pointer transition"
          title="Close Terminal"
        >
        </div>
        <div
          id="minimize-btn"
          class="w-3 h-3 bg-[#FFBD2E] rounded-full cursor-pointer transition"
          title="Minimize Terminal"
        >
        </div>
        <div
          id="maximize-btn"
          class="w-3 h-3 bg-[#27C93F] rounded-full cursor-pointer transition"
          title="Maximize Terminal"
        >
        </div>
        <span
          class="text-[11px] font-mono text-on-surface-variant font-medium ml-4"
          >titus-automation - zsh</span
        >
      </div>
      <div class="flex items-center space-x-2">
        <button
          id="font-smaller"
          class="text-[10px] font-mono text-on-surface-variant hover:text-secondary transition-colors px-2 py-1"
          title="Decrease Font Size">A-</button
        >
        <button
          id="font-bigger"
          class="text-[10px] font-mono text-on-surface-variant hover:text-secondary transition-colors px-2 py-1"
          title="Increase Font Size">A+</button
        >
      </div>
    </div>

    <!-- Terminal Body -->
    <div
      id="terminal-body"
      class="bg-slate-950 rounded-lg overflow-hidden border border-white/5 min-w-0"
    >
      <div
        class="p-3 sm:p-6 font-mono text-[11px] sm:text-[13px] leading-relaxed h-[320px] lg:h-[400px] relative overflow-hidden flex flex-col min-w-0"
      >
        <!-- Scrollable content area -->
        <div
          id="terminal-content"
          class="flex-1 overflow-y-auto overflow-x-hidden pr-2"
          style="scrollbar-width: thin; scrollbar-color: #4cd7f6 transparent;"
        >
          <!-- Intro animation plays here, then replaced by interactive content -->
          <div id="terminal-intro"></div>
          <div id="terminal-interactive" class="hidden">
            <div class="mb-2 truncate">
              <span class="text-tertiary"
                >Welcome to TestBot Terminal v2.1.0</span
              >
            </div>
            <div class="text-on-surface-variant mb-3 text-[10px] sm:text-xs">
              <span class="text-secondary">New to terminals?</span> Click the suggestions
              below or type commands.
            </div>

            <!-- Quick Command Buttons -->
            <div class="mb-4 space-y-2 mx-1">
              <div class="flex flex-wrap gap-1 sm:gap-2">
                <button
                  class="px-2 py-1 sm:px-3 sm:py-1.5 rounded-lg bg-surface-container-high/80 border border-outline-variant/20 hover:border-secondary/40 text-[8px] sm:text-[10px] uppercase tracking-wider sm:tracking-widest font-bold font-mono text-on-surface-variant hover:text-secondary transition-all hover:scale-105"
                  id="btn-whoami"
                >
                  [whoami] About Me
                </button>
                <button
                  class="px-2 py-1 sm:px-3 sm:py-1.5 rounded-lg bg-surface-container-high/80 border border-outline-variant/20 hover:border-secondary/40 text-[8px] sm:text-[10px] uppercase tracking-wider sm:tracking-widest font-bold font-mono text-on-surface-variant hover:text-secondary transition-all hover:scale-105"
                  id="btn-skills"
                >
                  [skills] My Skills
                </button>
                <button
                  class="px-2 py-1 sm:px-3 sm:py-1.5 rounded-lg bg-surface-container-high/80 border border-outline-variant/20 hover:border-secondary/40 text-[8px] sm:text-[10px] uppercase tracking-wider sm:tracking-widest font-bold font-mono text-on-surface-variant hover:text-secondary transition-all hover:scale-105"
                  id="btn-contact"
                >
                  [contact] Contact
                </button>
                <button
                  class="px-2 py-1 sm:px-3 sm:py-1.5 rounded-lg bg-surface-container-high/80 border border-outline-variant/20 hover:border-secondary/40 text-[8px] sm:text-[10px] uppercase tracking-wider sm:tracking-widest font-bold font-mono text-on-surface-variant hover:text-secondary transition-all hover:scale-105"
                  id="btn-projects"
                >
                  [projects] Projects
                </button>
                <button
                  class="px-2 py-1 sm:px-3 sm:py-1.5 rounded-lg bg-surface-container-high/80 border border-outline-variant/20 hover:border-secondary/40 text-[8px] sm:text-[10px] uppercase tracking-wider sm:tracking-widest font-bold font-mono text-on-surface-variant hover:text-secondary transition-all hover:scale-105"
                  id="btn-hire-me"
                >
                  [hire] Hire Me
                </button>
              </div>
              <div class="flex flex-wrap gap-1 sm:gap-2">
                <button
                  class="px-2 py-1 sm:px-3 sm:py-1.5 rounded-lg bg-surface-container-high/80 border border-outline-variant/20 hover:border-secondary/40 text-[8px] sm:text-[10px] uppercase tracking-wider sm:tracking-widest font-bold font-mono text-on-surface-variant hover:text-secondary transition-all hover:scale-105"
                  id="btn-experience"
                >
                  [experience] Work History
                </button>
                <button
                  class="px-2 py-1 sm:px-3 sm:py-1.5 rounded-lg bg-surface-container-high/80 border border-outline-variant/20 hover:border-secondary/40 text-[8px] sm:text-[10px] uppercase tracking-wider sm:tracking-widest font-bold font-mono text-on-surface-variant hover:text-secondary transition-all hover:scale-105"
                  id="btn-blog"
                >
                  [blog] TestBot Chronicles
                </button>
                <button
                  class="px-2 py-1 sm:px-3 sm:py-1.5 rounded-lg bg-surface-container-high/80 border border-outline-variant/20 hover:border-secondary/40 text-[8px] sm:text-[10px] uppercase tracking-wider sm:tracking-widest font-bold font-mono text-on-surface-variant hover:text-secondary transition-all hover:scale-105"
                  id="btn-logo"
                >
                  [logo] ASCII Art
                </button>
                <button
                  class="px-2 py-1 sm:px-3 sm:py-1.5 rounded-lg bg-surface-container-high/80 border border-outline-variant/20 hover:border-secondary/40 text-[8px] sm:text-[10px] uppercase tracking-wider sm:tracking-widest font-bold font-mono text-on-surface-variant hover:text-secondary transition-all hover:scale-105"
                  id="btn-help"
                >
                  [help] All Commands
                </button>
              </div>
            </div>

            <div class="text-on-surface-variant mb-4 text-xs">
              <span class="text-secondary">tip:</span> Use Tab for auto-complete,
              ↑↓ arrows for history
            </div>
          </div>
        </div>

        <!-- Fixed command line at bottom -->
        <div class="relative mt-4 border-t border-secondary/20 pt-4">
          <div class="flex items-center">
            <span class="text-secondary mr-2">titus-automation $</span>
            <span class="block-cursor"></span><input
              type="text"
              id="terminal-input"
              class="bg-transparent text-on-surface outline-none flex-1 font-mono"
              placeholder="Type a command or click suggestions above..."
              autocomplete="off"
              spellcheck="false"
            />
          </div>

          <!-- Auto-suggestions dropdown -->
          <div
            id="suggestions"
            class="absolute bottom-full left-0 right-0 bg-surface-container-lowest border border-secondary/30 rounded-md hidden z-10 max-h-32 overflow-y-auto mb-2"
          >
          </div>
        </div>

        <!-- Particles effect -->
        <div id="particles" class="absolute inset-0 pointer-events-none"></div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  class InteractiveTerminal {
    constructor() {
      this.input = document.getElementById("terminal-input");
      this.content = document.getElementById("terminal-content");
      this.suggestions = document.getElementById("suggestions");
      this.commandHistory = [];
      this.historyIndex = -1;
      this.showingSuggestions = false;
      this.outputQueue = [];
      this.queueRunning = false;

      // Store the initial content to restore on clear
      this.initialContent = this.content.innerHTML;

      this.commands = {
        help: this.showHelp.bind(this),
        whoami: this.showWhoami.bind(this),
        whoistitus: this.showWhoIsTitus.bind(this),
        skills: this.showSkills.bind(this),
        "skills.json": this.showSkillsJson.bind(this),
        projects: this.showProjects.bind(this),
        contact: this.showContact.bind(this),
        ls: this.listDirectory.bind(this),
        cat: this.catFile.bind(this),
        npm: this.npmCommand.bind(this),
        git: this.gitCommand.bind(this),
        docker: this.dockerCommand.bind(this),
        ping: this.pingCommand.bind(this),
        sudo: this.sudoCommand.bind(this),
        clear: this.clearTerminal.bind(this),
        exit: this.exitTerminal.bind(this),
        "hire-me": this.hireMe.bind(this),
        about: this.showAbout.bind(this),
        blog: this.showBlog.bind(this),
        logo: this.showLogo.bind(this),
        ascii: this.showLogo.bind(this),
        experience: this.showExperience.bind(this),
      };

      this.introPlaying = true;
      this.introTimeouts = [];
      this.introContainer = document.getElementById("terminal-intro");
      this.interactiveContainer = document.getElementById(
        "terminal-interactive",
      );

      this.setupEventListeners();
      this.setupWindowControls();
      this.setupFontControls();
      this.playIntro();
    }

    playIntro() {
      const lines = [
        {
          text: '<span class="text-secondary">titus-automation $</span> <span class="text-on-surface">npm run automate --env=production</span>',
          delay: 0,
        },
        {
          text: '<span class="text-on-surface-variant/60 italic"># Handshaking with Core API clusters...</span>',
          delay: 600,
        },
        {
          text: '<span class="text-green-400 font-bold">[PASS]</span>  <span class="text-on-surface/80">Payload Schema Validation: 0.04s</span>',
          delay: 1200,
        },
        {
          text: '<span class="text-green-400 font-bold">[PASS]</span>  <span class="text-on-surface/80">Concurrency Stress Test (10k/sec)</span>',
          delay: 1800,
        },
        {
          text: '<span class="text-green-400 font-bold">[PASS]</span>  <span class="text-on-surface/80">Cross-Browser Pixel Sync (99.98% match)</span>',
          delay: 2400,
        },
        {
          text: '<span class="text-green-400 font-bold">[PASS]</span>  <span class="text-on-surface/80">Latency Benchmarks: Avg 112ms</span>',
          delay: 3000,
        },
        {
          text: '<span class="text-tertiary font-bold">➜ Deployment Gate Status: CLEAR</span>',
          delay: 3600,
        },
      ];

      lines.forEach(({ text, delay }) => {
        const t = setTimeout(() => {
          if (!this.introPlaying) return;
          const div = document.createElement("div");
          div.className = "mb-2";
          div.innerHTML = text;
          this.introContainer.appendChild(div);
          this.content.scrollTop = this.content.scrollHeight;
        }, delay);
        this.introTimeouts.push(t);
      });

      // After intro finishes, transition to interactive mode
      const finishTimeout = setTimeout(() => {
        if (!this.introPlaying) return;
        this.finishIntro();
      }, 4800);
      this.introTimeouts.push(finishTimeout);
    }

    skipIntro() {
      if (!this.introPlaying) return;
      this.introTimeouts.forEach((t) => clearTimeout(t));
      this.introTimeouts = [];
      this.finishIntro();
    }

    finishIntro() {
      this.introPlaying = false;
      this.introContainer.classList.add("hidden");
      this.interactiveContainer.classList.remove("hidden");
      this.initialContent = this.content.innerHTML;
      this.setupButtonListeners();
      this.focusInput();
    }

    setupEventListeners() {
      this.input.addEventListener("keydown", (e) => {
        if (this.introPlaying) {
          this.skipIntro();
          return;
        }
        if (e.key === "Enter") {
          this.hideSuggestions();
          this.processCommand();
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          this.navigateHistory(-1);
        } else if (e.key === "ArrowDown") {
          e.preventDefault();
          this.navigateHistory(1);
        } else if (e.key === "Tab") {
          e.preventDefault();
          this.autoComplete();
        } else if (e.key === "Escape") {
          this.hideSuggestions();
        }
      });

      this.input.addEventListener("input", () => {
        this.showSuggestions();
      });

      this.input.addEventListener("blur", () => {
        // Hide suggestions after a small delay to allow clicking
        setTimeout(() => this.hideSuggestions(), 150);
      });

      // Focus input when clicking anywhere in terminal
      document.addEventListener("click", (e) => {
        if (e.target.closest("#terminal-body")) {
          if (this.introPlaying) {
            this.skipIntro();
          }
          this.focusInput();
        }
      });
    }

    setupButtonListeners() {
      const buttons = [
        { id: "btn-whoami", command: "whoami" },
        { id: "btn-skills", command: "skills" },
        { id: "btn-contact", command: "contact" },
        { id: "btn-projects", command: "projects" },
        { id: "btn-hire-me", command: "hire-me" },
        { id: "btn-experience", command: "experience" },
        { id: "btn-blog", command: "blog" },
        { id: "btn-logo", command: "logo" },
        { id: "btn-help", command: "help" },
      ];

      buttons.forEach(({ id, command }) => {
        const button = document.getElementById(id);
        if (button) {
          button.addEventListener("click", (e) => {
            e.preventDefault();
            e.stopPropagation();
            this.executeQuickCommand(command);
          });
        }
      });
    }

    setupWindowControls() {
      const terminal = document.getElementById("terminal-container");
      const terminalBody = document.getElementById("terminal-body");

      // Close button (red) - minimizes terminal
      const closeBtn = document.getElementById("close-btn");
      if (closeBtn) {
        closeBtn.addEventListener("click", () => {
          this.addOutput(
            "Terminal session ended. Refresh page to restart.",
            "terminal-orange",
          );
          this.input.disabled = true;
          this.input.placeholder = "Terminal closed. Refresh page to restart.";
          if (terminalBody) terminalBody.style.opacity = "0.3";
        });
      }

      // Minimize button (yellow) - toggles compact mode
      let isMinimized = false;
      const minimizeBtn = document.getElementById("minimize-btn");
      if (minimizeBtn) {
        minimizeBtn.addEventListener("click", () => {
          if (!isMinimized) {
            // Responsive minimize height
            if (terminalBody) {
              if (window.innerWidth < 640) {
                terminalBody.style.height = "120px";
              } else if (window.innerWidth < 1024) {
                terminalBody.style.height = "140px";
              } else {
                terminalBody.style.height = "150px";
              }
            }
            this.addOutput(
              "Terminal minimized. Click yellow button to restore.",
              "terminal-orange",
            );
            isMinimized = true;
          } else {
            // Restore to responsive height
            if (terminalBody) {
              terminalBody.style.height = "";
            }
            this.addOutput(
              "Terminal restored to normal size.",
              "terminal-blue",
            );
            isMinimized = false;
          }
          this.scrollToBottom();
        });
      }

      // Maximize button (green) - toggles fullscreen mode
      let isMaximized = false;
      const maximizeBtn = document.getElementById("maximize-btn");
      if (maximizeBtn) {
        maximizeBtn.addEventListener("click", () => {
          if (!isMaximized) {
            // Expand left and right with negative margins + increase height
            if (terminal) {
              terminal.style.marginLeft = "-6rem";
              terminal.style.marginRight = "-6rem";
              terminal.style.width = "calc(100% + 12rem)";
            }
            if (terminalBody) {
              terminalBody.style.height = "70vh";
            }

            this.addOutput(
              "Terminal maximized in all directions.",
              "terminal-green",
            );
            isMaximized = true;
          } else {
            // Restore to original size
            if (terminal) {
              terminal.style.marginLeft = "";
              terminal.style.marginRight = "";
              terminal.style.width = "";
            }
            if (terminalBody) {
              terminalBody.style.height = "";
            }
            this.addOutput(
              "Terminal restored to normal size.",
              "terminal-blue",
            );
            isMaximized = false;
          }
          this.scrollToBottom();
        });
      }
    }

    setupFontControls() {
      const terminalBody = document.getElementById("terminal-body");
      let currentFontSize = 14; // Default font size in pixels

      // Font size decrease button
      const fontSmallerBtn = document.getElementById("font-smaller");
      if (fontSmallerBtn) {
        fontSmallerBtn.addEventListener("click", () => {
          if (currentFontSize > 10) {
            // Minimum font size
            currentFontSize -= 2;
            if (terminalBody) {
              terminalBody.style.fontSize = currentFontSize + "px";
            }
            this.addOutput(
              `Font size decreased to ${currentFontSize}px`,
              "terminal-blue",
            );
            this.scrollToBottom();
          } else {
            this.addOutput(
              "Font size is already at minimum (10px)",
              "terminal-orange",
            );
            this.scrollToBottom();
          }
        });
      }

      // Font size increase button
      const fontBiggerBtn = document.getElementById("font-bigger");
      if (fontBiggerBtn) {
        fontBiggerBtn.addEventListener("click", () => {
          if (currentFontSize < 24) {
            // Maximum font size
            currentFontSize += 2;
            if (terminalBody) {
              terminalBody.style.fontSize = currentFontSize + "px";
            }
            this.addOutput(
              `Font size increased to ${currentFontSize}px`,
              "terminal-green",
            );
            this.scrollToBottom();
          } else {
            this.addOutput(
              "Font size is already at maximum (24px)",
              "terminal-orange",
            );
            this.scrollToBottom();
          }
        });
      }
    }

    focusInput() {
      this.input.focus();
    }

    executeQuickCommand(command) {
      this.input.value = command;
      this.processCommand();
    }

    showSuggestions() {
      const input = this.input.value.toLowerCase().trim();
      if (!input) {
        this.hideSuggestions();
        return;
      }

      const matches = Object.keys(this.commands).filter(
        (cmd) => cmd.startsWith(input) && cmd !== input,
      );

      if (matches.length === 0) {
        this.hideSuggestions();
        return;
      }

      this.suggestions.innerHTML = "";
      matches.slice(0, 5).forEach((cmd) => {
        const div = document.createElement("div");
        div.className =
          "p-2 hover:bg-terminal-green/20 cursor-pointer text-terminal-gray text-sm";
        div.textContent = cmd;
        div.addEventListener("click", () => {
          this.input.value = cmd;
          this.hideSuggestions();
          this.processCommand();
        });
        this.suggestions.appendChild(div);
      });

      this.suggestions.classList.remove("hidden");
      this.showingSuggestions = true;
    }

    hideSuggestions() {
      this.suggestions.classList.add("hidden");
      this.showingSuggestions = false;
    }

    processCommand() {
      const command = this.input.value.trim();
      if (command) {
        this.addToHistory(command);
        this.executeCommand(command);
      }
      this.input.value = "";
      this.historyIndex = -1;
    }

    addToHistory(command) {
      this.commandHistory.unshift(command);
      if (this.commandHistory.length > 50) {
        this.commandHistory.pop();
      }
    }

    navigateHistory(direction) {
      if (
        direction === -1 &&
        this.historyIndex < this.commandHistory.length - 1
      ) {
        this.historyIndex++;
      } else if (direction === 1 && this.historyIndex > -1) {
        this.historyIndex--;
      }

      if (this.historyIndex >= 0) {
        this.input.value = this.commandHistory[this.historyIndex];
      } else {
        this.input.value = "";
      }
    }

    autoComplete() {
      const partial = this.input.value.toLowerCase();
      const matches = Object.keys(this.commands).filter((cmd) =>
        cmd.startsWith(partial),
      );

      if (matches.length === 1) {
        this.input.value = matches[0];
      } else if (matches.length > 1) {
        // Show suggestions dropdown instead of adding to terminal output
        this.showSuggestions();
        // Briefly show all matches in a compact format
        const maxShow = 5;
        const displayMatches = matches.slice(0, maxShow);
        const more =
          matches.length > maxShow
            ? ` (+${matches.length - maxShow} more)`
            : "";
        this.input.placeholder = `Suggestions: ${displayMatches.join(", ")}${more}`;

        // Reset placeholder after a few seconds
        setTimeout(() => {
          this.input.placeholder =
            "Type a command or click suggestions above...";
        }, 3000);
      }
    }

    executeCommand(command) {
      // Add separator line before new command (except for first command)
      if (this.content.children.length > 6) {
        // Skip separator for welcome message + buttons
        this.addSeparator();
      }

      // Show the command that was typed
      this.addOutput("titus-automation $ " + command, "terminal-green");

      const [cmd, ...args] = command.toLowerCase().split(" ");

      if (this.commands[cmd]) {
        this.commands[cmd](args);
      } else {
        this.addOutput(
          "Command not found: " + cmd + ". Type 'help' for available commands.",
          "terminal-orange",
        );
      }

      this.scrollToBottom();
    }

    addOutput(text, className = "terminal-gray") {
      this.outputQueue.push({ type: "line", text, className });
      this.processQueue();
    }

    addSeparator() {
      this.outputQueue.push({ type: "separator" });
      this.processQueue();
    }

    processQueue() {
      if (this.queueRunning) return;
      this.queueRunning = true;
      this.drainQueue();
    }

    drainQueue() {
      if (this.outputQueue.length === 0) {
        this.queueRunning = false;
        return;
      }
      const item = this.outputQueue.shift();
      const el = document.createElement("div");

      if (item.type === "separator") {
        el.className = "border-t border-secondary/20 my-3";
        this.content.appendChild(el);
        this.content.scrollTop = this.content.scrollHeight;
        setTimeout(() => this.drainQueue(), 60);
        return;
      }

      el.className = `text-${item.className} mb-1`;
      el.innerHTML = item.text;
      el.style.opacity = "0";
      this.content.appendChild(el);
      this.content.scrollTop = this.content.scrollHeight;

      // Pop in after a frame
      requestAnimationFrame(() => {
        el.style.transition = "opacity 0.12s ease";
        el.style.opacity = "1";
      });

      // Wait before showing next line
      const delay = item.text === "" ? 30 : 120;
      setTimeout(() => this.drainQueue(), delay);
    }

    scrollToBottom() {
      setTimeout(() => {
        this.content.scrollTop = this.content.scrollHeight;
      }, 100);
    }

    // Command implementations
    showHelp() {
      this.addOutput('Available commands:', 'terminal-blue');
      this.addOutput('  whoami        - Who is behind the terminal', 'terminal-gray');
      this.addOutput('  whoistitus    - The full backstory', 'terminal-gray');
      this.addOutput('  skills        - Technical expertise', 'terminal-gray');
      this.addOutput('  skills.json   - Skills as structured data', 'terminal-gray');
      this.addOutput('  projects      - Portfolio and builds', 'terminal-gray');
      this.addOutput('  experience    - Career timeline', 'terminal-gray');
      this.addOutput('  contact       - How to reach me', 'terminal-gray');
      this.addOutput('  blog          - TestBot Chronicles', 'terminal-gray');
      this.addOutput('  ls            - List directory', 'terminal-gray');
      this.addOutput('  git log       - Commit history', 'terminal-gray');
      this.addOutput('  npm test      - Run the test suite', 'terminal-gray');
      this.addOutput('  docker ps     - Active services', 'terminal-gray');
      this.addOutput('  ping status   - Availability check', 'terminal-gray');
      this.addOutput('  hire-me       - Start a collaboration', 'terminal-gray');
      this.addOutput('  logo / ascii  - The alpaca', 'terminal-gray');
      this.addOutput('  clear         - Clear terminal', 'terminal-gray');
      this.addOutput('  exit          - End session', 'terminal-gray');
      this.addOutput('', 'terminal-gray');
      this.addOutput('[*] Easter eggs exist. Try: sudo make-coffee', 'terminal-purple');
    }

    showWhoami() {
      this.addOutput('[>] Quentin Goossens @ Titus Consulting', 'terminal-blue');
      this.addOutput('', 'terminal-gray');
